

# --- NewsData.io ---
# Get a free dev key at https://newsdata.io/register (keys look like `pub_<hex>`).
# The legacy `NEWSAPI_KEY` name is still accepted for backward compatibility.
NEWSDATA_API_KEY=your_newsdata_io_key_here

# --- JWT / Auth ---
# Generate a strong random secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default: 7 days)
JWT_EXPIRE_MINUTES=10080

# --- News scope ---
# ISO 3166-1 alpha-2 country code that the "National" filter resolves to.
# Examples: in (India), us (United States), gb (United Kingdom), ng (Nigeria).
# The "International" filter ignores this and pulls global headlines.
DEFAULT_COUNTRY=in

# --- Database ---
# SQLite file lives next to the backend app by default.
DATABASE_URL=sqlite:///./current_affairs.db

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
APP_NAME=Current Affairs API
DEBUG=true
