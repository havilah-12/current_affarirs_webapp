# docker compose env file - copy to `.env` and fill in real values.
# `docker compose` automatically loads `.env` from the same directory.

# --- REQUIRED ---

# NewsData.io API key. Sign up free at https://newsdata.io/register
# Keys look like: pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEWSDATA_API_KEY=your_newsdata_io_key_here

# JWT signing secret. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_to_a_long_random_string

# --- OPTIONAL OVERRIDES (sensible defaults shown) ---

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ISO 3166-1 alpha-2 default country for the news feed.
DEFAULT_COUNTRY=in

# Comma-separated list of allowed CORS origins. Only matters if you call
# the backend directly (port 8000); the frontend container uses same-origin
# /api proxying so CORS isn't in the request path.
CORS_ORIGINS=http://localhost:8080

APP_NAME=Current Affairs API
DEBUG=false
